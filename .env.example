# Azure OpenAI (AI Foundry) Configuration
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Azure AI Search (Foundry IQ) Configuration
# Used for grounded retrieval of destination knowledge.
# Leave unset to run without retrieval — the app works with demo data only.
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net/
AZURE_SEARCH_API_KEY=your-search-admin-key-here
AZURE_SEARCH_KNOWLEDGE_BASE=wanderboard-travel-kb
AZURE_SEARCH_API_VERSION=2026-04-01
AZURE_SEARCH_INDEX=wanderboard-travel-index

# Optional: Enable development logging for retrieval payloads
# WANDERBOARD_DEV_LOGGING=1
